# PostgreSQL connection string (required for persistent storage on Vercel)
# Get a free database at https://neon.tech
# DATABASE_URL=postgresql://user:password@host/dbname

# Alternative env var name (Vercel Postgres integration sets this automatically)
# POSTGRES_URL=postgresql://user:password@host/dbname

# Admin password for write access (default: bigcountry)
# ADMIN_PASSWORD=your-secret-password

# Optional: custom SQLite database path for local development
# WORD_CLOUD_DB_PATH=./data/wordcloud.db
